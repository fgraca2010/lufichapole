# Copie este arquivo para .env.local e preencha os valores reais.
# .env.local NUNCA deve ser commitado (já está no .gitignore).

# Supabase — Project Settings > API (não é a senha do banco)
NEXT_PUBLIC_SUPABASE_URL=https://ttzxktdmqqthfpahdfjw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Apenas necessário se algo precisar de conexão direta ao Postgres
# (ex.: migrations via CLI). Project Settings > Database > Connection string.
# Rotacionada em: <preencher data>
SUPABASE_DB_PASSWORD=

# URL pública do site (usada nos redirects de OAuth e no site_url do Supabase Auth)
NEXT_PUBLIC_SITE_URL=https://lufichapole.vercel.app
